# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — pisahkan dengan koma kalau lebih dari 1
# Contoh: https://potutrely.vercel.app,https://potutrely-laravel.koyeb.app
ALLOWED_ORIGINS=https://your-laravel.koyeb.app,https://your-frontend.vercel.app

# Port (otomatis di-set Render, tidak perlu diubah)
PORT=8001
